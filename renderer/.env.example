# Worker base URL (no trailing slash). Used at build time by Vite.
VITE_PARCHI_API=https://parchi-api.<account>.workers.dev

# Cloudflare Turnstile public sitekey. OPTIONAL — anti-spam gate for browser
# comments. If empty, browser comments still work (open, rate-limited per IP).
VITE_TURNSTILE_SITEKEY=
