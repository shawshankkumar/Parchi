# parchi — environment for `parchi setup`.
# Copy to `.env`, fill in, and `source .env` (or export inline) before setup.
# `.env` is gitignored — these values are NEVER committed.

# --- Cloudflare auth (pick ONE) ---
# Simplest: run `bunx wrangler login` (interactive) and leave these blank.
# Unattended / Claude-driven: set a token instead of logging in.
#   Create at: dashboard → My Profile → API Tokens → "Edit Cloudflare Workers".
CLOUDFLARE_API_TOKEN=
# Only needed if your login/token spans MULTIPLE Cloudflare accounts
# (dashboard → Workers & Pages → Account ID). Otherwise leave blank.
CLOUDFLARE_ACCOUNT_ID=

# --- Optional: agent key ---
# Leave blank and `parchi setup` generates one. Set it to reuse an existing key
# (it must match the AGENT_KEY secret on your Worker).
PARCHI_AGENT_KEY=

# --- Optional: Cloudflare Turnstile (human/browser comments) ---
# Without these, only CLI/agent comments work (which is fine for solo/agent use).
# Create a widget at dashboard → Turnstile.
TURNSTILE_SECRET=
VITE_TURNSTILE_SITEKEY=
